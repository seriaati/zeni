---
import t from "../i18n/en.json";
const c = t.cta;
---

<section class="cta" id="get-started">
  <div class="cta-inner reveal">
    <h2 class="cta-title">{c.title}<br /><em>{c.titleEm}</em></h2>
    <p class="cta-sub">{c.sub}</p>
    <div class="cta-actions">
      <a href={t.site.appUrl} class="btn-primary">{c.btnPrimary}</a>
    </div>
  </div>
</section>

<style>
.cta {
  padding: clamp(64px, 8vw, 100px) 0;
}

.cta-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 clamp(20px, 5vw, 48px);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20px;
}

.cta-title {
  font-family: var(--font-display);
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400;
  line-height: 1.08;
  color: var(--ink);
}
.cta-title em { font-style: italic; color: var(--forest-light); }

.cta-sub {
  font-size: clamp(14px, 1.5vw, 16px);
  color: var(--ink-mid);
  line-height: 1.65;
  max-width: 420px;
}

.cta-actions {
  display: flex;
  gap: 12px;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 8px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--forest);
  color: var(--cream);
  font-size: 15px;
  font-weight: 500;
  padding: 13px 26px;
  border-radius: var(--radius);
  transition:
    opacity 0.15s,
    transform 0.2s cubic-bezier(0.25, 1, 0.5, 1),
    box-shadow 0.2s cubic-bezier(0.25, 1, 0.5, 1);
}
.btn-primary:hover {
  opacity: 0.88;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px oklch(18% 0.01 80 / 0.2);
}
.btn-primary:active {
  transform: translateY(0) scale(0.97);
  opacity: 1;
  box-shadow: none;
  transition-duration: 0.08s;
}

.btn-outline {
  display: inline-flex;
  align-items: center;
  font-size: 15px;
  font-weight: 500;
  color: var(--ink);
  border: 1.5px solid var(--sand-dark);
  padding: 12px 24px;
  border-radius: var(--radius);
  transition:
    border-color 0.2s,
    background 0.2s,
    transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);
}
.btn-outline:hover {
  border-color: var(--forest);
  background: var(--cream-dark);
  transform: translateY(-2px);
}
.btn-outline:active {
  transform: translateY(0) scale(0.97);
  transition-duration: 0.08s;
}
</style>
